# IoT Monitor - Environment Configuration
# Copy to .env and fill in values

# App
APP_NAME=IoT Monitor
DEBUG=false

# Database (SQLite default)
DATABASE_URL=sqlite+aiosqlite:///./iot_monitor.db

# JWT - MUST change in production
JWT_SECRET=change-me-in-production-use-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# eWeLink - from https://dev.ewelink.cc/
EWELINK_CLIENT_ID=
EWELINK_CLIENT_SECRET=
# Redirect URI registered in eWeLink app (e.g. https://your-domain.com/api/ewelink/callback)
EWELINK_REDIRECT_URI=

# Encryption for eWeLink token storage (32 bytes, base64 or passphrase)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-32-bytes-base64!!

# Default admin (change on first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Tapo cloud credentials (required for newer L510/L530 and some WiFi switches)
# Use your TP-Link/Tapo app email and password
TAPO_USERNAME=
TAPO_PASSWORD=

# Polling intervals (seconds)
CAMERA_POLL_INTERVAL=10
TAPO_POLL_INTERVAL=30

# go2rtc (Docker: http://go2rtc:1984)
GO2RTC_URL=http://localhost:1984
# URL for "Open in go2rtc" link in browser (e.g. http://10.0.10.225:1984)
GO2RTC_PUBLIC_URL=http://10.0.10.225:1984
